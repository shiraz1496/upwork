generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  admin
  bidder
}

enum MemberStatus {
  active
  inactive
}

enum CoverageEntityType {
  offer
  message_thread
  proposal
}

model TeamMember {
  id        String       @id @default(cuid())
  name      String
  email     String       @unique
  role      Role         @default(bidder)
  status    MemberStatus @default(active)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  tokens            ExtensionToken[]
  coverageItems     CoverageItem[]
  notesAuthored     CoachingNote[]   @relation("NoteAuthor")
  notesReceived     CoachingNote[]   @relation("NoteRecipient")
  capturedSnapshots   Snapshot[]
  capturedProposals   Proposal[] @relation("ProposalCapturedBy")
  submittedProposals  Proposal[] @relation("ProposalSubmittedBy")
  capturedAlerts    Alert[]
  pageVisits        PageVisit[]
  visitLogs         VisitLog[]
  capturedProfiles  FreelancerProfile[]
  nudgesReceived    Nudge[] @relation("NudgeBidder")
  nudgesCreated     Nudge[] @relation("NudgeCreatedBy")
}

model ExtensionToken {
  id         String     @id @default(cuid())
  memberId   String
  member     TeamMember @relation(fields: [memberId], references: [id], onDelete: Cascade)
  tokenHash  String     @unique
  label      String?
  lastUsedAt DateTime?
  revokedAt  DateTime?
  createdAt  DateTime   @default(now())

  @@index([memberId])
}

model CoverageItem {
  id           String             @id @default(cuid())
  memberId     String
  member       TeamMember         @relation(fields: [memberId], references: [id], onDelete: Cascade)
  accountId    String
  account      Account            @relation(fields: [accountId], references: [id])
  entityType   CoverageEntityType
  entityId     String
  openUrl      String?
  reasonTags   String[]
  referencedAt DateTime           @default(now())
  capturedAt   DateTime?
  priority     Int                @default(0)

  @@unique([memberId, accountId, entityType, entityId])
  @@index([memberId, capturedAt])
}

model CoachingNote {
  id          String     @id @default(cuid())
  authorId    String
  author      TeamMember @relation("NoteAuthor", fields: [authorId], references: [id])
  recipientId String
  recipient   TeamMember @relation("NoteRecipient", fields: [recipientId], references: [id])
  proposalId  String?
  proposal    Proposal?  @relation(fields: [proposalId], references: [id])
  body        String     @db.Text
  readAt      DateTime?
  createdAt   DateTime   @default(now())

  @@index([recipientId, readAt])
  @@index([proposalId])
}


model Account {
  id              String         @id @default(cuid())
  freelancerId    String         @unique
  name            String
  jss             Float?
  connectsBalance Int?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  snapshots       Snapshot[]
  proposals       Proposal[]
  alerts          Alert[]
  coverageItems   CoverageItem[]
  pageVisits      PageVisit[]
  visitLogs       VisitLog[]
  profile         FreelancerProfile?
}

model FreelancerProfile {
  id                  String   @id @default(cuid())
  accountId           String   @unique
  account             Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  title               String?
  photoUrl            String?
  location            String?
  hourlyRate          String?
  totalEarnings       String?
  totalJobs           Int?
  totalHours          Int?
  overview            String?  @db.Text
  skills              String[]
  capturedAt          DateTime @default(now())
  updatedAt           DateTime @updatedAt
  capturedByUserId    String?
  capturedByUser      TeamMember? @relation(fields: [capturedByUserId], references: [id])

  @@index([capturedByUserId])
}

model Alert {
  id                String    @id @default(cuid())
  accountId         String
  account           Account   @relation(fields: [accountId], references: [id])
  type              String
  title             String
  senderName        String?
  preview           String?
  url               String?
  roomId            String?
  jobTitle          String?
  date              String?
  freelancerReplied Boolean   @default(false)
  lastMessageSender String?
  lastMessageText   String?
  lastMessageTime   String?
  needsAttention    Boolean   @default(false)
  isUnread          Boolean   @default(false)
  read              Boolean   @default(false)
  replied           Boolean   @default(false)
  notifiedAt        DateTime  @default(now())
  remindedAt        DateTime?
  createdAt         DateTime  @default(now())

  capturedByUserId String?
  capturedByUser   TeamMember? @relation(fields: [capturedByUserId], references: [id])
  capturedAt       DateTime?

  @@index([accountId])
  @@index([type])
  @@index([roomId])
  @@index([capturedByUserId])
}

model Snapshot {
  id                          String   @id @default(cuid())
  accountId                   String
  account                     Account  @relation(fields: [accountId], references: [id])
  capturedAt                  DateTime
  startTimestamp              String?
  endTimestamp                String?
  range                       String?
  jss                         Float?
  connectsBalance             Int?
  proposalsSentBoosted        Int      @default(0)
  proposalsSentOrganic        Int      @default(0)
  proposalsViewedBoosted      Int      @default(0)
  proposalsViewedOrganic      Int      @default(0)
  proposalsInterviewedBoosted Int      @default(0)
  proposalsInterviewedOrganic Int      @default(0)
  proposalsHiredBoosted       Int      @default(0)
  proposalsHiredOrganic       Int      @default(0)
  seriesJson                  String?
  createdAt                   DateTime @default(now())

  capturedByUserId String?
  capturedByUser   TeamMember? @relation(fields: [capturedByUserId], references: [id])

  @@index([accountId, capturedAt])
  @@index([capturedByUserId])
}


model Proposal {
  id                    String    @id @default(cuid())
  accountId             String
  account               Account   @relation(fields: [accountId], references: [id])
  jobTitle              String?
  jobUrl                String?
  jobCategory           String?
  status                String?
  section               String?
  boosted               Boolean   @default(false)
  boostStatus           String?
  viewedByClient        Boolean   @default(false)
  coverLetter           String?   @db.Text
  clientNote            String?   @db.Text
  clientName            String?
  clientCountry         String?
  connectsSpent         Int?
  submittedAt           DateTime?
  submittedViaExtension Boolean   @default(false)
  profileUsed           String?
  proposedRate          String?
  receivedRate          String?
  rateIncrease          String?
  bidConnects           Int?
  jobBudget             String?
  jobHoursPerWeek       String?
  jobDuration           String?
  jobExperienceLevel    String?
  jobDescription        String?   @db.Text
  jobSkills             String[]
  jobPostedDate         String?
  clientRating          Float?
  clientReviews         Int?
  clientReviewScore     String?
  clientCity            String?
  clientJobsPosted      Int?
  clientHireRate        Int?
  clientOpenJobs        Int?
  clientTotalSpent      String?
  clientHires           Int?
  clientActiveHires     Int?
  clientAvgRate         String?
  clientTotalHours      String?
  clientMemberSince     String?
  clientPaymentVerified Boolean   @default(false)
  createdAt             DateTime  @default(now())

  capturedByUserId   String?
  capturedByUser     TeamMember? @relation("ProposalCapturedBy", fields: [capturedByUserId], references: [id])
  capturedAt         DateTime?
  submittedByUserId  String?
  submittedByUser    TeamMember? @relation("ProposalSubmittedBy", fields: [submittedByUserId], references: [id])

  coachingNotes CoachingNote[]
  nudges        Nudge[]

  @@index([accountId])
  @@index([capturedByUserId])
  @@index([submittedByUserId])
}

model Nudge {
  id          String     @id @default(cuid())
  bidderId    String
  bidder      TeamMember @relation("NudgeBidder", fields: [bidderId], references: [id])
  proposalId  String
  proposal    Proposal   @relation(fields: [proposalId], references: [id], onDelete: Cascade)
  createdById String
  createdBy   TeamMember @relation("NudgeCreatedBy", fields: [createdById], references: [id])
  createdAt   DateTime   @default(now())
  deliveredAt DateTime?

  @@index([bidderId, deliveredAt])
  @@index([proposalId])
}

model BiddingCriterion {
  id        String   @id @default(cuid())
  key       String   // e.g. "client_total_spent", "client_rating"
  operator  String   @default("gte") // "gte", "lte", "eq"
  value     String   // threshold value e.g. "1000"
  required  Boolean  @default(true)
  active    Boolean  @default(true)
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model RequiredPage {
  id            String      @id @default(cuid())
  name          String
  url           String
  cooldownHours Int         @default(1)
  createdAt     DateTime    @default(now())
  visits        PageVisit[]
  visitLogs     VisitLog[]
}

model PageVisit {
  id        String       @id @default(cuid())
  pageId    String
  page      RequiredPage @relation(fields: [pageId], references: [id], onDelete: Cascade)
  memberId  String
  member    TeamMember   @relation(fields: [memberId], references: [id], onDelete: Cascade)
  accountId String?
  account   Account?     @relation(fields: [accountId], references: [id])
  visitedAt DateTime     @default(now())

  @@unique([pageId, memberId, accountId])
  @@index([memberId])
  @@index([pageId])
  @@index([memberId, accountId])
}

model VisitLog {
  id        String       @id @default(cuid())
  pageId    String
  page      RequiredPage @relation(fields: [pageId], references: [id], onDelete: Cascade)
  memberId  String
  member    TeamMember   @relation(fields: [memberId], references: [id], onDelete: Cascade)
  accountId String?
  account   Account?     @relation(fields: [accountId], references: [id])
  coveredAt DateTime     @default(now())

  // Each row = one coverage event (bidder visited page while it was uncovered)
  @@index([memberId, coveredAt])
  @@index([coveredAt])
}
