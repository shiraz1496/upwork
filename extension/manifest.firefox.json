{
  "manifest_version": 3,
  "name": "Upwork Tracker",
  "version": "2.0.0",
  "description": "Scrapes and tracks proposal stats, JSS, connects, and job data across all your Upwork accounts.",
  "permissions": ["storage", "notifications", "alarms", "scripting", "webNavigation"],
  "host_permissions": [
    "https://www.upwork.com/*",
    "http://localhost:3000/*",
    "https://*.ngrok-free.app/*",
    "https://*.ngrok.io/*",
    "https://*.vercel.app/*",
    "https://482b-2407-d000-1a-3ee7-b012-6c0-3cf3-774c.ngrok-free.app/*",
    "https://upwork-tracking-tool.vercel.app/*"
  ],
  "background": {
    "scripts": ["src/background.js"]
  },
  "content_scripts": [{
    "matches": ["https://www.upwork.com/*"],
    "js": ["src/content.js"],
    "run_at": "document_idle"
  }],
  "web_accessible_resources": [{
    "resources": ["src/injected.js", "src/account-detector.js"],
    "matches": ["https://www.upwork.com/*"]
  }],
  "action": {
    "default_popup": "src/popup.html",
    "default_title": "Upwork Tracker",
    "default_icon": { "128": "src/icon128.png" }
  },
  "icons": { "128": "src/icon128.png" },
  "browser_specific_settings": {
    "gecko": {
      "id": "upwork-tracker@extension"
    }
  }
}
